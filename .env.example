# 华为云 ECS/VPC 凭据 —— 复制为 .env 并填入真实值，或直接 export 到环境。
# 切勿把真实 AK/SK 提交进仓库。
export HW_ECS_AK="your-access-key-id"
export HW_ECS_SK="your-secret-access-key"
export HW_ECS_PROJECT_ID="your-project-id"
# 可选（默认 cn-north-4）：
# export HW_ECS_ENDPOINT="https://ecs.cn-north-4.myhuaweicloud.com"
# export HW_VPC_ENDPOINT="https://vpc.cn-north-4.myhuaweicloud.com"
